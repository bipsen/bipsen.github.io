    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "%matplotlib inline\n",
    "\n",
    "x = np.array(list(range(9)))\n",
    "y = x**2\n",
    "\n",
    "plt.plot(x, y)\n",
    "plt.xlabel('More and more')\n",
    "plt.ylabel('This much')\n",
    "plt.title('Important numbers')\n"
   ]
